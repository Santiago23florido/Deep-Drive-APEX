<?xml version="1.0"?>
<robot name="rc_car" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="lidar_noise_std" default="0.0"/>
  <xacro:property name="lidar_noise_std" value="$(arg lidar_noise_std)"/>
  <!-- Basic dimensions -->
  <xacro:property name="chassis_length" value="0.46"/>
  <xacro:property name="chassis_width" value="0.28"/>
  <xacro:property name="chassis_height" value="0.10"/>
  <xacro:property name="chassis_clearance" value="0.03"/>
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_thickness" value="0.03"/>
  <xacro:property name="wheelbase_m" value="0.30"/>
  <xacro:property name="rear_axle_offset_x" value="-0.15"/>
  <xacro:property name="front_axle_offset_x" value="${rear_axle_offset_x + wheelbase_m}"/>
  <xacro:property name="steering_limit_rad" value="0.3141592654"/>
  <xacro:property name="lidar_offset_x" value="0.18"/>
  <xacro:property name="lidar_offset_z" value="0.12"/>

  <!-- Placement helpers -->
  <xacro:property name="wheel_base_x" value="${front_axle_offset_x}"/>
  <xacro:property name="wheel_track_y" value="${chassis_width / 2.0 + wheel_thickness / 2.0 - 0.01}"/>
  <xacro:property name="axle_height" value="${wheel_radius}"/>

  <!-- Mass and inertia approximations -->
  <xacro:property name="chassis_mass" value="3.0"/>
  <xacro:property name="wheel_mass" value="0.25"/>
  <xacro:property name="steer_mass" value="0.05"/>

  <xacro:property name="chassis_ixx" value="${chassis_mass / 12.0 * (chassis_height*chassis_height + chassis_width*chassis_width)}"/>
  <xacro:property name="chassis_iyy" value="${chassis_mass / 12.0 * (chassis_length*chassis_length + chassis_height*chassis_height)}"/>
  <xacro:property name="chassis_izz" value="${chassis_mass / 12.0 * (chassis_length*chassis_length + chassis_width*chassis_width)}"/>

  <xacro:property name="wheel_ixx" value="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"/>
  <xacro:property name="wheel_iyy" value="${wheel_ixx}"/>
  <xacro:property name="wheel_izz" value="${0.5 * wheel_mass * wheel_radius * wheel_radius}"/>

  <!-- Materials -->
  <material name="chassis_grey">
    <color rgba="0.27 0.27 0.3 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <xacro:macro name="wheel" params="name parent xyz">
    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wheel_mass}"/>
        <inertia ixx="${wheel_ixx}" ixy="0.0" ixz="0.0" iyy="${wheel_iyy}" iyz="0.0" izz="${wheel_izz}"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
      </collision>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="1.5708 0 0"/>
      <axis xyz="0 0 -1"/>
    </joint>
    <gazebo reference="${name}">
      <mu1>1.2</mu1>
      <mu2>1.2</mu2>
      <kp>80000.0</kp>
      <kd>20.0</kd>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="steered_wheel" params="name parent xyz">
    <link name="${name}_steer">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${steer_mass}"/>
        <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.01" length="0.04"/>
        </geometry>
        <material name="chassis_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.01" length="0.04"/>
        </geometry>
      </collision>
    </link>
    <joint name="${name}_steer_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${name}_steer"/>
      <origin xyz="${xyz}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-${steering_limit_rad}" upper="${steering_limit_rad}" effort="10.0" velocity="3.5"/>
    </joint>
    <xacro:wheel name="${name}" parent="${name}_steer" xyz="0 0 0"/>
  </xacro:macro>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 ${chassis_height / 2.0 + chassis_clearance}" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <inertia ixx="${chassis_ixx}" ixy="0.0" ixz="0.0" iyy="${chassis_iyy}" iyz="0.0" izz="${chassis_izz}"/>
    </inertial>
    <visual>
      <origin xyz="0 0 ${chassis_height / 2.0 + chassis_clearance}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height / 2.0 + chassis_clearance}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
  </link>

  <link name="rear_axle">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0" iyy="0.00002" iyz="0.0" izz="0.00002"/>
    </inertial>
  </link>

  <link name="laser">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.03"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
  </link>

  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.02 0.01"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
  </link>

  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.02"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
  </link>

  <joint name="rear_axle_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_axle"/>
    <origin xyz="${rear_axle_offset_x} 0 ${axle_height}" rpy="0 0 0"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="${lidar_offset_x} 0 ${lidar_offset_z}" rpy="0 0 0"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- Match the real APEX planar mount: sensor Y points forward, so the
         kinematics estimator's planar_mount_yaw_deg=-90 rotates back into
         vehicle-forward X. -->
    <origin xyz="0.02 0 ${chassis_height / 2.0 + 0.03}" rpy="0 0 1.57079632679"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.25 0.0 0.20" rpy="0 0 0"/>
  </joint>

  <gazebo reference="laser">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>12</update_rate>
      <visualize>true</visualize>
      <topic>/apex/sim/scan</topic>
      <!-- Gazebo modern uses gz_frame_id for sensor messages. Keep the ideal
           scan anchored to the URDF laser link so slam_toolbox can use the
           existing base_link -> laser TF from robot_state_publisher instead of
           a hand-written sensor TF. -->
      <gz_frame_id>laser</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <!-- Optional light LiDAR noise for robustness sweeps. Default stays at
             zero so the baseline ideal scan remains perfectly reproducible. -->
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>${lidar_noise_std}</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>120</update_rate>
      <topic>/apex/sim/imu</topic>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.002</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.002</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.002</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.02</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.02</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.02</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>/camera/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <xacro:steered_wheel name="front_left_wheel" parent="base_link" xyz="${wheel_base_x} ${wheel_track_y} ${axle_height}"/>
  <xacro:steered_wheel name="front_right_wheel" parent="base_link" xyz="${wheel_base_x} ${-wheel_track_y} ${axle_height}"/>
  <xacro:wheel name="rear_left_wheel" parent="base_link" xyz="${-wheel_base_x} ${wheel_track_y} ${axle_height}"/>
  <xacro:wheel name="rear_right_wheel" parent="base_link" xyz="${-wheel_base_x} ${-wheel_track_y} ${axle_height}"/>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <mu1>1.4</mu1>
    <mu2>1.35</mu2>
    <kp>100000.0</kp>
    <kd>25.0</kd>
  </gazebo>

  <gazebo>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>
    <plugin
      filename="gz-sim-pose-publisher-system"
      name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>rear_left_wheel_joint</joint_name>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>front_left_wheel_steer_joint</joint_name>
      <topic>/model/rc_car/joint/front_left_wheel_steer_joint/cmd_pos</topic>
      <p_gain>28.0</p_gain>
      <i_gain>0.2</i_gain>
      <d_gain>0.7</d_gain>
      <cmd_max>${steering_limit_rad}</cmd_max>
      <cmd_min>-${steering_limit_rad}</cmd_min>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>front_right_wheel_steer_joint</joint_name>
      <topic>/model/rc_car/joint/front_right_wheel_steer_joint/cmd_pos</topic>
      <p_gain>28.0</p_gain>
      <i_gain>0.2</i_gain>
      <d_gain>0.7</d_gain>
      <cmd_max>${steering_limit_rad}</cmd_max>
      <cmd_min>-${steering_limit_rad}</cmd_min>
    </plugin>
  </gazebo>
</robot>
